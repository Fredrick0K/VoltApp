<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/metro_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="48dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/metro_button_square"
            android:src="@android:drawable/ic_menu_revert"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:contentDescription="Volver"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tv_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡ 1.0"
        android:textSize="48sp"
        android:textColor="@color/white"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tv_dev"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@Fredrick0K"
        android:textSize="20sp"
        android:textColor="@color/metro_primary"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/tv_github"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="github.com/Fredrick0K/VoltApp"
        android:textSize="14sp"
        android:textColor="@color/metro_text_muted"
        android:layout_marginTop="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Desliza a la derecha para volver"
        android:textSize="12sp"
        android:textColor="@color/metro_text_muted"
        android:layout_marginTop="48dp"
        android:alpha="0.5"/>

</LinearLayout>
