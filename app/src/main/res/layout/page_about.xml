<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/metro_background">

    <!-- Header with back button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/metro_button_square"
            android:src="@android:drawable/ic_menu_revert"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Volver"/>

        <TextView
            android:layout_width="113dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/plus_jakarta_sans_medium"
            android:letterSpacing="0.2"
            android:text="ACERCA DE"
            android:textColor="@color/metro_text_muted"
            android:textSize="17sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/metro_primary"/>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="32dp">

            <!-- App Name / Version -->
            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VOLT$"
                android:textSize="48sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginTop="32dp"/>

            <TextView
                android:id="@+id/tv_version_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Versión 1.0.3"
                android:textSize="14sp"
                android:textColor="@color/metro_text_muted"
                android:layout_marginTop="8dp"/>

            <!-- Info Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="48dp">

                <!-- Developer -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@color/metro_surface_tile"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DESARROLLADOR"
                        android:textSize="10sp"
                        android:textColor="@color/metro_text_muted"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tv_dev"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@Fredrick0K"
                        android:textSize="18sp"
                        android:textColor="@color/metro_primary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- GitHub -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@color/metro_surface_tile"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GITHUB"
                        android:textSize="10sp"
                        android:textColor="@color/metro_text_muted"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tv_github"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="github.com/Fredrick0K/VoltApp"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Description -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@color/metro_surface_tile">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Version"
                        android:textSize="10sp"
                        android:textColor="@color/metro_text_muted"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v1.0.3"
                        android:textSize="14sp"
                        android:textColor="@color/metro_text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Authtor Rights -->
            <TextView
                android:layout_width="310dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:alpha="0.5"
                android:text="Derechos de autor © 2026 @Fredrick0K. Todos los derechos reservados."
                android:textColor="@color/metro_text_muted"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
